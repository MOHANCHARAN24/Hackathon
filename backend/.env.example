
# LLM Provider: gemini or groq
LLM_PROVIDER=gemini

# Gemini (Google)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Groq (alternative LLM)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# College / University identity
COLLEGE_NAME=Vignan's Foundation for Science, Technology and Research (VFSTR)
COLLEGE_ADDRESS=Vadlamudi, Guntur, Andhra Pradesh 522213

# Admin and CORS
ADMIN_PASSWORD=Charan@2411
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Runtime mode and startup checks
APP_ENV=development
STRICT_STARTUP_VALIDATION=false

# Optional storage overrides (useful for Docker)
DOCS_PATH=./docs
CHROMA_PERSIST_PATH=./vectorstore
SQLITE_DB_PATH=./feedback.db

